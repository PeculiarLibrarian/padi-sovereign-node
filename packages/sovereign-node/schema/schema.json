{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PADI Ingest Schema",
  "type": "object",
  "required": ["timestamp", "nonce", "v", "verifiedBy", "epoch", "gridScore", "invisibilityCoefficient"],
  "additionalProperties": false,
  "properties": {
    "gridScore": { 
      "type": "integer",
      "minimum": 0,
      "maximum": 1003
    },
    "invisibilityCoefficient": { 
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "verifiedBy": { 
      "type": "string",
      "pattern": "^(Samuel Muriithi Gitandu|PeculiarLibrarian|Nairobi-Bureau-Node)$"
    },
    "timestamp": { "type": "integer" },
    "nonce": { 
      "type": "string", 
      "minLength": 8,
      "pattern": "^[a-zA-Z0-9]+$" 
    },
    "epoch": { "type": "integer", "minimum": 0 },
    "v": { 
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+[a-z]?$"
    },
    "context": { "type": "string", "maxLength": 256 }
  }
}
