@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix : <http://padi.tech/schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# SHACL: Validating Node Declarations
:NodeShape a sh:NodeShape ;
    sh:property [
        sh:path :nodeId ;
        sh:minCount 1 ;
        sh:datatype xsd:string 
    ] .

# Identity Management
:SamuelNode 
    :name "Samuel Muriithi Gitandu" ;
    :authorizedPublicKey "-----BEGIN PUBLIC KEY-----\n..." ;
    :isRevoked false . # Set to true to semantically kill this key
