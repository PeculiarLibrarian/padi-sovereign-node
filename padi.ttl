@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix : <http://padi.tech/schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# SHACL: Validating Sovereign Node Declarations
:NodeShape a sh:NodeShape ;
    sh:property [ sh:path :nodeId ; sh:minCount 1 ; sh:datatype xsd:string ] ;
    sh:property [ sh:path :publicKey ; sh:minCount 1 ] ;
    sh:property [ sh:path :timestamp ; sh:minCount 1 ; sh:datatype xsd:integer ] .

# SHACL: Validating Structural Data
:StructuralShape a sh:NodeShape ;
    sh:property [ sh:path :gridScore ; sh:maxInclusive 1003 ] .

# Authority Management
:SamuelNode 
    :name "Samuel Muriithi Gitandu" ;
    :authorizedPublicKey "-----BEGIN PUBLIC KEY-----\n..." ;
    :isRevoked false .
